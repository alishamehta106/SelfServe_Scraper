generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Hotel {
  id              String   @id @default(cuid())
  websiteUrl      String
  reviewToken     String   @unique
  operatorToken   String?  @unique
  scrapedData     Json
  gapReport       Json
  missingFields   Json
  normalizedData  Json?
  provenance      Json?
  status          String
  uploadedFiles   Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}
